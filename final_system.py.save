import hashlib
from PIL import Image
import io
import os

def get_real_sha256(image_path):
    if not os.path.exists(image_path):
        return None
    try:
        with Image.open(image_path) as img:
            buf = io.BytesIO()
            img.save(buf, format=img.format)
            return hashlib.sha256(buf.getvalue()).hexdigest()
    except Exception:
        return None

class MedicalBlockchainAI:
    def __init__(self, image_folder="images"):
        self.image_folder = image_folder
    
        if not os.path.exists(image_folder):
            os.makedirs(image_folder)
        
        self.image_list = sorted([f for f in os.listdir(image_folder) if f.endswith(('.png', '.jpg', '.jpeg'))])
        
        self.ledger = {img: get_real_sha256(os.path.join(image_folder, img)) for img in self.image_list}

    def verify_image(self, img_name):
        path = os.path.join(self.image_folder, img_name)
        current_hash = get_real_sha256(path)
        
        print("\n" + "-"*40)
        print(f" SCANNING File: {img_name}")
        
        if current_hash == self.ledger.get(img_name):
            print("STATUS: SUCCESS - Hash Matches")
            print("SYSTEM: Integrity Verified. AI Diagnosis: Normal")
        else:
            print(" STATUS: FAILURE - Hash Mismatch")
            print("  SECURITY: Unauthorized Modification Detected! AI BLOCKED.")
        print("-"*40)


def main():
    system = MedicalBlockchainAI()
    
    if not system.image_list:
        print("No images found in /images folder!")
        return

    while True:
        print("\n" + "="*50)
        print("   MEDICAL BLOCKCHAIN-AI: SELECT IMAGE TO TEST")
        print("="*50)
        
        
        for i, img in enumerate(system.image_list):
            print(f"[{i}] {img}")
        
        choice = input("\nEnter image number to test (or 'q' to quit): ")
        
        if choice.lower() == 'q':
            print("Shutting down system...")
            break
            
        try:
            idx = int(choice)
            selected_img = system.image_list[idx]
            system.verify_image(selected_img)
            
            input("\nPress [Enter] to return to the list...")

